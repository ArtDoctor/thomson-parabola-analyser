[flake8]
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    venv,
    .venv,
    yolo-tune/venv,
    build,
    dist,
    *.egg-info
max-line-length = 120
# Ignore trailing whitespace errors
ignore = W291, W293
# W291: trailing whitespace
# W293: blank line contains whitespace

# Matplotlib backend + sys.path must run before project imports
per-file-ignores =
    web/backend/main.py: E402
    oblisk/__init__.py: F401
    oblisk/analysis/spectra.py: F401
